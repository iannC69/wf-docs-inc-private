name: Discord Push Notification

on:
  push:
    branches: [ main, develop ]

jobs:
  notify:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 2

      - name: Get changed files
        id: changed
        run: |
          ALL_FILES=$(git diff --name-only HEAD~1 HEAD 2>/dev/null || echo "")
          if [ -z "$ALL_FILES" ]; then
            echo "files_count=0" >> $GITHUB_OUTPUT
            echo "files_display=No file changes detected" >> $GITHUB_OUTPUT
          else
            FILES_COUNT=$(echo "$ALL_FILES" | wc -l | tr -d ' ')
            SHOWN=$(echo "$ALL_FILES" | head -25 | sed 's/^/• /')

            if [ "$FILES_COUNT" -gt 25 ]; then
              EXTRA=$((FILES_COUNT - 25))
              SHOWN=$(printf "%s\n\n… si inca %d fisiere" "$SHOWN" "$EXTRA")
            fi

            echo "files_count=$FILES_COUNT" >> $GITHUB_OUTPUT

            # Use heredoc for safe multiline output
            {
              echo "files_display<<ENDOFFILES"
              echo "$SHOWN"
              echo "ENDOFFILES"
            } >> $GITHUB_OUTPUT
          fi

      - name: Get user info
        id: userinfo
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          # Resolve username from multiple sources
          USERNAME="${{ github.event.head_commit.author.username }}"
          [ -z "$USERNAME" ] && USERNAME="${{ github.actor }}"
          [ -z "$USERNAME" ] && USERNAME="${{ github.event.pusher.name }}"
          echo "username=$USERNAME" >> $GITHUB_OUTPUT

          if [ -n "$USERNAME" ]; then
            RESPONSE=$(curl -s -H "Authorization: token $GITHUB_TOKEN" \
              "https://api.github.com/users/$USERNAME" 2>/dev/null || echo "{}")

            AVATAR_URL=$(echo "$RESPONSE" | jq -r '.avatar_url // empty')
            NAME=$(echo "$RESPONSE" | jq -r '.name // empty')

            # Append size param for crisp avatar in Discord embed
            if [ -n "$AVATAR_URL" ]; then
              echo "avatar_url=${AVATAR_URL}&s=128" >> $GITHUB_OUTPUT
            else
              echo "avatar_url=https://github.com/${USERNAME}.png?size=128" >> $GITHUB_OUTPUT
            fi

            if [ -n "$NAME" ] && [ "$NAME" != "null" ]; then
              echo "display_name=$NAME" >> $GITHUB_OUTPUT
            else
              echo "display_name=$USERNAME" >> $GITHUB_OUTPUT
            fi
          else
            echo "avatar_url=https://github.githubassets.com/images/modules/logos_page/GitHub-Mark.png" >> $GITHUB_OUTPUT
            echo "display_name=Unknown User" >> $GITHUB_OUTPUT
          fi

      - name: Send Discord notification
        env:
          DISCORD_WEBHOOK: ${{ secrets.DISCORD_WEBHOOK_URL }}
          COMMIT_MSG: ${{ github.event.head_commit.message }}
          AUTHOR: ${{ steps.userinfo.outputs.display_name }}
          AVATAR: ${{ steps.userinfo.outputs.avatar_url }}
          USERNAME: ${{ steps.userinfo.outputs.username }}
          BRANCH: ${{ github.ref_name }}
          REPO: ${{ github.repository }}
          FULL_SHA: ${{ github.sha }}
          COMMIT_URL: ${{ github.event.head_commit.url }}
          COMPARE_URL: ${{ github.event.compare }}
          FILES_COUNT: ${{ steps.changed.outputs.files_count }}
          FILES_DISPLAY: ${{ steps.changed.outputs.files_display }}
        run: |
          SHORT_SHA="${FULL_SHA:0:7}"
          TIMESTAMP=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
          COMMIT_TITLE=$(echo "$COMMIT_MSG" | head -n1)

          # Write files to temp so jq can read them safely
          printf '%s' "$FILES_DISPLAY" > /tmp/files_list.txt

          # Build JSON entirely inside jq (no shell backtick issues)
          jq -n \
            --arg repo "$REPO" \
            --arg url "$COMPARE_URL" \
            --arg author "$AUTHOR" \
            --arg avatar "$AVATAR" \
            --arg username "$USERNAME" \
            --arg committitle "$COMMIT_TITLE" \
            --arg branch "$BRANCH" \
            --arg shortsha "$SHORT_SHA" \
            --arg commiturl "$COMMIT_URL" \
            --arg filescount "$FILES_COUNT" \
            --rawfile filesraw /tmp/files_list.txt \
            --arg timestamp "$TIMESTAMP" \
            '{
              embeds: [{
                title: ("🚀 New Push to `" + $repo + "`"),
                url: $url,
                color: 16750848,
                author: {
                  name: $author,
                  icon_url: $avatar,
                  url: ("https://github.com/" + $username)
                },
                thumbnail: {
                  url: $avatar
                },
                fields: [
                  {name: "⚡ Commit", value: $committitle, inline: false},
                  {name: "Branch", value: ("🌿 `" + $branch + "`"), inline: true},
                  {name: "SHA", value: ("[`" + $shortsha + "`](" + $commiturl + ")"), inline: true},
                  {name: "Changes", value: ("📦 **" + $filescount + "** files changed"), inline: true},
                  {name: "📁 Changed Files", value: ("```\n" + $filesraw + "\n```"), inline: false}
                ],
                footer: {
                  text: "Wildfire.ro Docs",
                  icon_url: "https://github.com/WildFiire.png?size=32"
                },
                timestamp: $timestamp
              }]
            }' > /tmp/payload.json

          # Send it
          curl -s -X POST "$DISCORD_WEBHOOK" \
            -H "Content-Type: application/json" \
            -d @/tmp/payload.json