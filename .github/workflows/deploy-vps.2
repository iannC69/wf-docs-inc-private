name: Deploy DOCS to VPS

on:
  push:
    branches:
      - main # Trigger deployment when pushing to the main branch

jobs:
  deploy:
    runs-on: ubuntu-latest
    
    steps:
      - name: Deploy to VPS
        uses: appleboy/ssh-action@v1.0.3
        with:
          host: ${{ secrets.VPS_HOST }}       # Your VPS IP or domain
          username: ${{ secrets.VPS_USER }}   # e.g., root or ubuntu
          key: ${{ secrets.VPS_SSH_KEY }}     # Private SSH key for authentication
          script: |
            # Navigate to the project directory
            cd /var/www/wiki
            
            # Pull the latest changes from the main branch
            git fetch --all
            git reset --hard origin/main
            
            # Create the .env file with the GitHub Token
            echo "VITE_GITHUB_TOKEN=${{ secrets.VITE_GITHUB_TOKEN }}" > .env

            # Install dependencies (force include devDependencies for the build)
            npm install --include=dev

            # Build the static VitePress files
            npm run docs:build

            # Restart the API server so it picks up updated code / .env
            pm2 restart wildfire-wiki-api --update-env

